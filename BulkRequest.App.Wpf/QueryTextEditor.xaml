<UserControl x:Class="BulkRequest.App.Wpf.QueryTextEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BulkRequest.App.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="120" d:DesignWidth="320">
    <DockPanel LastChildFill="True" Background="White">
        <GroupBox DockPanel.Dock="Bottom" Header="Настройка разметки">
            <WrapPanel>
                <CheckBox x:Name="_defaultSettingsCheckBox" Content="По умолчанию" IsChecked="True" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <Label Content="_Локаль:" Target="{Binding ElementName=_localeMarkTextBox}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <TextBox x:Name="_localeMarkTextBox" VerticalAlignment="Center" MinWidth="32" MaxWidth="96"/>
                <Label Content="_Ядро:" Target="{Binding ElementName=_kernelMarkTextBox}" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <TextBox x:Name="_kernelMarkTextBox" VerticalAlignment="Center" MinWidth="32" MaxWidth="96"/>
            </WrapPanel>
        </GroupBox>
        <GroupBox>
            <GroupBox.Header>
                <Label Content="_Текст запроса" Target="{Binding ElementName=_queryTextRichTextBox}"/>
            </GroupBox.Header>
            <RichTextBox x:Name="_queryTextRichTextBox">
                <RichTextBox.Resources>
                    <Style TargetType="Paragraph">
                        <Setter Property="Margin" Value="0"/>
                    </Style>
                </RichTextBox.Resources>
            </RichTextBox>
        </GroupBox>
    </DockPanel>
</UserControl>
